{
  "name": "idea",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Issue-driven, agent-built project. See docs/ and CLAUDE.md.",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "prettier": "^3.4.2",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^4.1.10"
  }
}
